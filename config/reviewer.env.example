# Required target repository.
REVIEWER_REPO=owner/repo

# Human-readable runner name appended to generated reviews.
REVIEWER_RUNNER_NAME=reviewer-vm

# GitHub App credentials. GoobReview posts reviews as the App's bot
# identity (<slug>[bot]), so it can APPROVE / REQUEST_CHANGES on PRs
# from any author. See docs/github-app-setup.md for the registration
# walkthrough; `scripts/configure.sh` will prompt for these values and
# auto-discover the installation ID for REVIEWER_REPO.
REVIEWER_APP_ID=
REVIEWER_APP_INSTALLATION_ID=
REVIEWER_APP_PRIVATE_KEY_PATH=/var/lib/goobreview/example/app-key.pem

# Optional: also skip PRs authored by this specific username. The App's
# own bot identity is always skipped. Set this if you want the App to
# ignore PRs from a particular human author too.
# REVIEWER_USER=

# Runtime state and logs. Prefer one state directory per reviewer identity.
REVIEWER_STATE=/var/lib/goobreview/example

# Template checkout path that cron should sync before each review tick.
REVIEWER_SYNC_REPO_DIR=/opt/goobreview/example
REVIEWER_SYNC_BRANCH=main

# Reviewer personality. Path to a file in config/personalities/, relative
# to the repo root or absolute. Personalities define the reviewer's role
# and (optionally) voice. To switch
# personalities, change this path. To add a new one, drop a .md file in
# config/personalities/ and point this at it.
REVIEWER_PERSONALITY_FILE=config/personalities/control.md

# Prompt payload manifest. Configure this with scripts/configure.sh or edit
# config/prompt-payload.json directly to choose the exact segments Gemini sees.
# REVIEWER_PROMPT_PAYLOAD_FILE=config/prompt-payload.json

# Gemini CLI model or routing alias.
REVIEWER_GEMINI_MODEL=auto
REVIEWER_GEMINI_TIMEOUT=600

# Default: review at most one successful post or dry-run per cron tick.
REVIEWER_MAX_PRS=1

# Advanced: override the required-checks gate at runtime without editing
# required-checks.json. Both vars must be set; the override is ignored unless
# REVIEWER_ALLOW_REQUIRED_CHECKS_OVERRIDE=1.
# REVIEWER_REQUIRED_CHECKS_JSON=["Unit tests","Build"]
# REVIEWER_ALLOW_REQUIRED_CHECKS_OVERRIDE=0
