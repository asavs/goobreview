# Required target repository.
REVIEWER_REPO=owner/repo

# Human-readable runner name appended to generated reviews.
REVIEWER_RUNNER_NAME=reviewer-vm

# GitHub App credentials. GoobReview posts reviews as the App's bot
# identity (<slug>[bot]), so it can APPROVE / REQUEST_CHANGES on PRs
# from any author. See docs/github-app-setup.md for the registration
# walkthrough; `scripts/configure.sh` prompts for missing values and can
# auto-detect REVIEWER_REPO plus installation ID when the App installation
# exposes exactly one repository.
REVIEWER_APP_ID=
REVIEWER_APP_INSTALLATION_ID=
REVIEWER_APP_PRIVATE_KEY_PATH=/var/lib/goobreview/example/app-key.pem

# Optional: also skip PRs authored by this specific username. The App's
# own bot identity is always skipped. Set this if you want the App to
# ignore PRs from a particular human author too.
# REVIEWER_USER=

# Runtime state and logs. Prefer one state directory per reviewer identity.
REVIEWER_STATE=/var/lib/goobreview/example
# PR-head snapshots and Antigravity CLI's isolated runtime live away from the App
# private key by default. Override only when you need a specific runtime path.
# REVIEWER_RUNTIME_STATE=/tmp/goobreview-runtime-goobreview
# Log rotation for log.txt, sync.log, and cron.log.
# REVIEWER_LOG_MAX_BYTES=1048576
# REVIEWER_LOG_ROTATE_KEEP=5

# GitHub API bounds. Shell curl calls use connect and overall timeouts,
# then retry safe transient GET failures this many times. The Node App-token
# helper uses REVIEWER_GITHUB_FETCH_TIMEOUT as its fetch abort timeout.
# REVIEWER_GITHUB_CONNECT_TIMEOUT=10
# REVIEWER_GITHUB_MAX_TIME=60
# REVIEWER_GITHUB_RETRIES=2
# REVIEWER_GITHUB_RETRY_SLEEP=1
# REVIEWER_GITHUB_FETCH_TIMEOUT=60
# Limit rows printed in all-check summaries and CI-failure review bodies.
# REVIEWER_CHECK_RUN_SUMMARY_LIMIT=200

# Template checkout path that cron should sync before each review tick.
REVIEWER_SYNC_REPO_DIR=/opt/goobreview/example
REVIEWER_SYNC_BRANCH=main
# Safety default: if sync fails, the scheduler tick exits before reviewing.
# Set to 1 only for an emergency/manual run from the current checkout.
# REVIEWER_ALLOW_STALE_CHECKOUT_ON_SYNC_FAILURE=0

# Posted review style. This controls the single review posted to GitHub.
# "none" uses config/personalities/control.md. "linus" uses
# config/personalities/linus.md. Research consent below never changes which
# style is posted.
REVIEWER_POSTED_PERSONALITY=none

# Research consent. When set to 1 on a public repository, live reviews retain
# paired control/Linus prompt+response artifacts under REVIEWER_STATE for
# later analysis. Private repositories are excluded from v1 research capture.
REVIEWER_RESEARCH_CONSENT=0

# Legacy/internal escape hatch. If REVIEWER_POSTED_PERSONALITY is unset, the
# daemon can still read a direct personality file path for old configs.
# REVIEWER_PERSONALITY_FILE=config/personalities/control.md

# Author-narrative blinding policy. The prompt composition itself is fixed
# (forks edit scripts/reviewer/lib/prompt.sh to change it); these flags only
# control what extra author-provided context the reviewer sees. The PR title,
# base branch, and head branch are always included as compact orientation.
# The author username and PR description are blinded by default; commit
# subjects are included by default as short orientation titles. 1=include,
# 0=blind.
# REVIEWER_INCLUDE_AUTHOR=0
# REVIEWER_INCLUDE_DESCRIPTION=0
# REVIEWER_INCLUDE_COMMIT_SUBJECTS=1

# Antigravity CLI model or routing alias.
REVIEWER_AGY_MODEL=auto
REVIEWER_AGY_TIMEOUT=600

# Prompt and artifact budgets. The diff degrades per file: a file's patch is
# either included whole or replaced with a marked omission (never cut
# mid-hunk). Other segment caps truncate deterministically and mark omitted
# context in the prompt. The global prompt cap fails closed before agy is
# invoked if enabled segments still exceed the safe bound.
# REVIEWER_MAX_PROMPT_BYTES=240000
# REVIEWER_MAX_ARTIFACT_BYTES=1000000
# REVIEWER_DIFF_MAX_BYTES=120000
# REVIEWER_DIFF_FILE_MAX_BYTES=40000
# REVIEWER_DESCRIPTION_MAX_BYTES=12000
# Include at most this many workflow files from .github/workflows.
# REVIEWER_CI_WORKFLOW_FILE_LIMIT=8
# Cap each included workflow file.
# REVIEWER_CI_WORKFLOW_FILE_MAX_BYTES=12000
# Include package scripts from at most this many package.json files.
# REVIEWER_CI_PACKAGE_SCRIPT_FILE_LIMIT=12
# Retain only the first non-empty line of the most recent prior review.
# REVIEWER_PREVIOUS_REVIEW_MAX_BYTES=500
# Include at most this many unresolved bot-created inline review threads.
# REVIEWER_PRIOR_THREAD_SUMMARY_LIMIT=12
# Cap each prior inline-thread subject included in the prompt.
# REVIEWER_PRIOR_THREAD_BODY_MAX_BYTES=500
# Retain this many commit subjects total, split between the first and last.
# REVIEWER_COMMIT_SUBJECTS_MAX=10

# Default: review at most one successful post or dry-run per cron tick.
REVIEWER_MAX_PRS=1
# Default: attempt at most REVIEWER_MAX_PRS non-skipped PRs per cron tick.
# Attempts include CI API reads, PR-head snapshot preparation, prompt assembly,
# agy calls, and review posting failures. Draft/already-reviewed skips do
# not count.
# REVIEWER_MAX_ATTEMPTS=1

# Advanced: override the required-checks gate at runtime without editing
# required-checks.json. Both vars must be set; the override is ignored unless
# REVIEWER_ALLOW_REQUIRED_CHECKS_OVERRIDE=1.
# REVIEWER_REQUIRED_CHECKS_JSON=["Unit tests","Build"]
# REVIEWER_ALLOW_REQUIRED_CHECKS_OVERRIDE=0
# Optional: apply labels such as agent-reviewed / agent-requested-changes.
# REVIEWER_APPLY_LABELS=1
# Optional: resolve unresolved inline review threads originally opened by
# this bot when the reviewer explicitly lists their handle (a slug derived
# from the thread's heading) in a "Resolved Prior Threads" section and GitHub
# says this App can resolve them. A confirming reply is posted into each thread
# before it is resolved.
# Default off: humans remain the only thread resolvers unless enabled.
# REVIEWER_AUTO_RESOLVE_BOT_THREADS=0
